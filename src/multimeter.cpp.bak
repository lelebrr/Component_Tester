// ============================================================================
// Component Tester PRO v3.0 - Multimestro AC/DC (Implementacao)
// Descricao: ZMPT101B para AC, INA219 para DC
// Versao: CYD Edition para ESP32-2432S028R
// ============================================================================

#include "multimeter.h"
#include "config.h"
#include <Wire.h>
#include <Adafruit_INA219.h>
#include <math.h>

// ============================================================================
// INSTANCIAS E VARIAVEIS
// ============================================================================
static Adafruit_INA219 ina219;
static bool ina219Initialized = false;

// Estado do multimetro
static MultimeterMode currentMode = MMODE_DC_VOLTAGE;
static MultimeterReading currentReading;

// Buffer circular para amostras RMS
static float acSamples[ZMPT_SAMPLES];
static int acSampleIndex = 0;
static unsigned long lastAcReadMs = 0;

// Variavel externa (definida em main.cpp)
extern float lastActivityMs;

// ============================================================================
// INICIALIZACAO
// ============================================================================
void multimeter_init() {
    DBG_PRINTLN("[MULTI] Inicializando multimetro...");

    // INA219 para DC
    Wire.begin(PIN_I2C_SDA, PIN_I2C_SCL);
    
    // Tenta inicializar o INA219
    uint8_t addr = INA219_I2C_ADDR;
    Wire.beginTransmission(addr);
    if (Wire.endTransmission() == 0) {
        ina219Initialized = true;
        ina219.begin(addr);
        
        // Configuracao do INA219
        // BRNG_32V = range de 32V
        // PG_320mA = gain de 320mA
        // ADC_12BIT = 12 bits de resolucao
        ina219.setCalibration_32V_2A();
        
        DBG_PRINTLN("[MULTI] INA219 OK");
    } else {
        DBG_PRINTLN("[MULTI] INA219 nao encontrado");
        ina219Initialized = false;
    }

    currentMode = MMODE_DC_VOLTAGE;
    DBG_PRINTLN("[MULTI] Multimestro pronto");
}

// ============================================================================
// LEITURAS DC (INA219)
// ============================================================================
float multimeter_read_dc_voltage() {
    if (!ina219Initialized) return 0.0f;
    return ina219.getBusVoltage_V();
}

float multimeter_read_dc_current() {
    if (!ina219Initialized) return 0.0f;
    return ina219.getCurrent_mA();
}

// ============================================================================
// LEITURAS AC (ZMPT101B)
// Usa amostragem rapida e calculo de True RMS
// ============================================================================
float multimeter_read_ac_voltage() {
    unsigned long startUs = micros();
    int count = 0;
    float sumSq = 0.0f;
    int raw;
    float v;

    // Coleta amostras
    while (count < ZMPT_SAMPLES) {
        raw = analogRead(PIN_ZMPT_AC);
        // Converte para tensao (0-3.3V -> 0-4095)
        v = ((float)raw - ZMPT_ZERO_POINT) * ADC_VOLTS_PER_BIT;
        sumSq += v * v;
        acSamples[count] = v;
        count++;

        // Taxa de amostragem - espera pelo proximo sample
        // Tempo por sample = 1 segundo / taxa
        while ((micros() - startUs) < (1000000UL / ZMPT_SAMPLE_RATE)) {
            // Busy-wait para timing preciso
        }
        startUs = micros();
    }

    // RMS = sqrt(soma(V^2) / N)
    float rms = sqrt(sumSq / (float)count);

    // Escala para tensao de linha (220V RMS -> 311V pico)
    // Fator de escala baseado na calibracao
    float vrms = rms * ZMPT_SCALE_FACTOR / (float)ZMPT_ZERO_POINT;
    return vrms;
}

// ============================================================================
// TRUE RMS CALCULATION
// ============================================================================
float calculate_true_rms(float* samples, int count) {
    if (count <= 0) return 0.0f;
    float sumSq = 0.0f;
    for (int i = 0; i < count; i++) {
        sumSq += samples[i] * samples[i];
    }
    return sqrt(sumSq / (float)count);
}

// ============================================================================
// LEITURA COMPLETA
// ============================================================================
MultimeterReading multimeter_read() {
    MultimeterReading r;
    r.mode = currentMode;
    r.timestamp = millis();
    r.valid = true;

    switch (currentMode) {
        case MMODE_DC_VOLTAGE:
            r.value = multimeter_read_dc_voltage();
            r.unit = "V";
            r.statusColor = (r.value > 30.0f) ? 
                UI_COLORS::DANGER : UI_COLORS::SUCCESS;
            break;

        case MMODE_AC_VOLTAGE:
            r.value = multimeter_read_ac_voltage();
            r.unit = "V";
            r.statusColor = (r.value > 250.0f) ? 
                UI_COLORS::WARNING : UI_COLORS::SUCCESS;
            break;

        case MMODE_DC_CURRENT:
            r.value = multimeter_read_dc_current();
            r.unit = "mA";
            r.statusColor = UI_COLORS::SUCCESS;
            break;

        case MMODE_AC_CURRENT:
            // Corrente AC estimada baseada na tensao AC
            // Assumindo carga resistiva (I = V / R)
            {
                float vac = multimeter_read_ac_voltage();
                r.value = vac / 220.0f; // Assumindo 220 ohms
                r.unit = "A";
                r.statusColor = UI_COLORS::SUCCESS;
            }
            break;

        case MMODE_RESISTANCE:
            // Resistencia medida via ADC
            {
                int raw = analogRead(PIN_PROBE_1);
                // Divisor de tensao com 3.3V
                // R = (Vout / Vin) * R referencia
                r.value = ((float)raw / 4095.0f) * 3300.0f;
                r.unit = "ohms";
                r.statusColor = (r.value < 10.0f) ? 
                    UI_COLORS::DANGER : UI_COLORS::SUCCESS;
            }
            break;

        case MMODE_CONTINUITY:
            // Teste de continuidade
            {
                int raw = analogRead(PIN_PROBE_1);
                r.value = (float)raw;
                r.unit = "ADC";
                // Menor que 100 = curto (buzzer)
                // Maior que 4000 = aberto
                r.statusColor = (r.value < 100.0f) ? 
                    UI_COLORS::SUCCESS : UI_COLORS::WARNING;
            }
            break;

        default:
            r.value = 0.0f;
            r.unit = "-";
            r.statusColor = UI_COLORS::UNKNOWN;
            r.valid = false;
            break;
    }

    return r;
}

// ============================================================================
// CALIBRACAO
// ============================================================================
void multimeter_calibrate_zmpt(float realVoltage) {
    // Corrige o fator de escala baseado na tensao real medida
    // com um multimetro de referencia
    // realVoltage tipicamente = 220V ou 110V
    float currentReading = multimeter_read_ac_voltage();
    if (currentReading > 1.0f) {
        float newFactor = realVoltage / currentReading * ZMPT_SCALE_FACTOR;
        DBG_PRINTF("[MULTI] ZMPT calibrado: fator = %.2f\n", newFactor);
    }
}

// ============================================================================
// MODO
// ============================================================================
void multimeter_set_mode(MultimeterMode mode) {
    currentMode = mode;
    DBG_PRINTF("[MULTI] Modo: %d\n", (int)mode);
}

MultimeterMode multimeter_get_mode() {
    return currentMode;
}

// ============================================================================
// UI - Desenhar tela do multimetro
// ============================================================================
void multimeter_draw(const MultimeterReading* reading) {
    tft.fillScreen(UI_COLORS::BACKGROUND);
    draw_status_bar();

    if (!reading) return;

    // Card grande no centro
    int16_t cx = 160, cy = 110;
    tft.fillRoundRect(cx - 130, cy - 70, 260, 140, 12, UI_COLORS::CARD_BG);
    tft.drawRoundRect(cx - 130, cy - 70, 260, 140, 12, reading->statusColor);

    // Modo
    const char* modeStr;
    switch (reading->mode) {
        case MMODE_DC_VOLTAGE: modeStr = "DC VOLTAGE"; break;
        case MMODE_AC_VOLTAGE:  modeStr = "AC VOLTAGE"; break;
        case MMODE_DC_CURRENT: modeStr = "DC CURRENT"; break;
        case MMODE_AC_CURRENT: modeStr = "AC CURRENT"; break;
        case MMODE_RESISTANCE: modeStr = "RESISTANCE"; break;
        case MMODE_CONTINUITY: modeStr = "CONTINUITY"; break;
        default: modeStr = "MULTIMETER"; break;
    }

    tft.setTextColor(UI_COLORS::TEXT_DIM);
    tft.setTextSize(2);
    tft.setCursor(cx - 60, cy - 55);
    tft.print(modeStr);

    // Valor
    char valStr[32];
    if (reading->valid) {
        if (reading->value >= 100.0f) {
            snprintf(valStr, sizeof(valStr), "%.1f", reading->value);
        } else if (reading->value >= 1.0f) {
            snprintf(valStr, sizeof(valStr), "%.2f", reading->value);
        } else {
            snprintf(valStr, sizeof(valStr), "%.3f", reading->value);
        }
    } else {
        snprintf(valStr, sizeof(valStr), "---");
    }

    tft.setTextColor(UI_COLORS::TEXT);
    tft.setTextSize(5);
    tft.setCursor(cx - 50, cy - 20);
    tft.print(valStr);
    tft.setTextSize(2);
    tft.setCursor(cx + 10, cy + 20);
    tft.print(reading->unit);

    draw_footer_modern();
}

// ============================================================================
// Handle da UI (loop principal)
// ============================================================================
void multimeter_handle() {
    lastActivityMs = millis();

    // Atualiza LED RGB - indicador de atividade
    static int phase = 0;
    static unsigned long lastToggle = 0;
    unsigned long now = millis();
    if (now - lastToggle > 500) {
        phase = !phase;
        // Alterna verde (atividade)
        if (phase) {
            tft.setPixel(10, 230, UI_COLORS::SUCCESS);
        } else {
            tft.setPixel(10, 230, UI_COLORS::BACKGROUND);
        }
        lastToggle = now;
    }

    // Leitura
    currentReading = multimeter_read();
    multimeter_draw(&currentReading);

    delay(100);
}